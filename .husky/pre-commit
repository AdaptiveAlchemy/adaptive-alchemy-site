#!/bin/sh

# Check for merge conflict markers in staged files
if git diff --cached | grep -qE '^\+([<>]{7} |={7}$)'; then
  echo "Merge conflict markers detected. Resolve conflicts before committing."
  exit 1
fi

# Check for private key material in staged files
if git diff --cached | grep -qE '^\+(-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY)'; then
  echo "Private key material detected. Remove before committing."
  exit 1
fi

# Block large files (> 500 KB)
for file in $(git diff --cached --name-only --diff-filter=ACM); do
  if [ -f "$file" ]; then
    size=$(wc -c < "$file" | tr -d '[:space:]')
    if [ "$size" -gt 512000 ]; then
      echo "Large file blocked: $file (${size} bytes). Use Git LFS for files > 500 KB."
      exit 1
    fi
  fi
done

# Check for filename case conflicts
conflicts=$(git ls-files | sort -f | uniq -id)
if [ -n "$conflicts" ]; then
  echo "Case-conflicting filenames detected:"
  printf '%s\n' "$conflicts"
  exit 1
fi

pnpm run pre-commit
