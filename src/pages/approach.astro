---
import CTABand from '@/components/sections/CTABand.astro'
import {
  FRAMEWORK_DIMENSIONS,
  FRAMEWORK_LEVELS,
  FRAMEWORK_NAME
} from '@/consts'
import PageLayout from '@/layouts/PageLayout.astro'
---

<PageLayout
  title="Our Approach"
  description="How Adaptive Alchemy assesses and transforms technology organizations. Our structured methodology, the Crucible Model framework, and the principles behind our work."
>
  <section class="px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-serif text-4xl text-text-primary md:text-5xl">
        Our Approach
      </h1>

      <div class="mt-12 space-y-6 text-lg leading-relaxed text-text-muted">
        <p>
          Every engagement begins with an honest assessment of where you
          actually are. Not where you think you are. We use a structured
          five-stage methodology &mdash; Assess, Design, Pilot, Transform,
          Operate &mdash; to establish a baseline, identify the highest-leverage
          opportunities, and sequence work so each stage builds on evidence from
          the one before it. The entry point for most engagements is The Signal
          Review: a 20-working-day assessment that produces a board-ready
          verdict on AI readiness.
        </p>
      </div>

      <!-- Framework placeholder -->
      <div class="mt-16">
        <h2 class="font-serif text-2xl text-text-primary">
          {FRAMEWORK_NAME}
        </h2>

        <p class="mt-4 text-text-muted">
          We assess organizations across {FRAMEWORK_DIMENSIONS.length} dimensions:
        </p>

        <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-5">
          {
            FRAMEWORK_DIMENSIONS.map((dim) => (
              <div class="rounded-lg border border-gold/20 bg-surface px-4 py-3 text-center">
                <span class="text-sm font-medium text-gold">{dim}</span>
              </div>
            ))
          }
        </div>

        <div class="mt-12 space-y-4">
          {
            FRAMEWORK_LEVELS.map(({ level, name, description }) => (
              <div class="flex items-start gap-4 rounded-lg border border-white/5 bg-surface p-4">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gold/10 text-sm font-medium text-gold">
                  {level}
                </div>
                <div>
                  <h3 class="font-medium text-text-primary">{name}</h3>
                  <p class="mt-1 text-sm text-text-muted">{description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <CTABand
    headline="Get a board-ready verdict in 20 working days."
    subheadline="The Signal Review is a structured assessment across five dimensions. At the end, you have an honest baseline and a prioritized roadmap. Book a 30-minute conversation to see whether it is the right starting point."
  />
</PageLayout>
