---
import { getCollection } from 'astro:content'

import CTABand from '@/components/sections/CTABand.astro'
import PageLayout from '@/layouts/PageLayout.astro'

const personas = (await getCollection('personas')).sort(
  (a, b) => a.data.order - b.data.order
)
---

<PageLayout
  title="Who We Help"
  description="Adaptive Alchemy works with PE/VC funds, CEOs, founders, CTOs, and companies with stalled AI projects. Product and technology strategy leadership — find the engagement model built for your situation."
>
  <section class="px-6 py-24">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="font-serif text-4xl text-text-primary md:text-5xl">
        Who We Help
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-text-muted">
        Every engagement starts with understanding your situation. Find the page
        that speaks to yours.
      </p>
    </div>
  </section>

  <section class="px-6 pb-24">
    <div class="mx-auto grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-2">
      {
        personas.map((persona) => (
          <a
            href={`/for/${persona.id.replace(/\.md$/, '')}/`}
            class="group rounded-lg border border-white/5 bg-surface p-8 transition-colors duration-200 hover:border-gold/30"
          >
            <p class="text-sm uppercase tracking-wide text-gold">
              {persona.data.hero.eyebrow}
            </p>
            <h2 class="mt-3 font-serif text-2xl text-text-primary transition-colors group-hover:text-gold">
              {persona.data.hero.headline}
            </h2>
            <p class="mt-3 text-text-muted">{persona.data.description}</p>
            <span class="mt-4 inline-block text-sm text-accent group-hover:text-accent-hover">
              Learn more &rarr;
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <CTABand
    headline="Not sure which fits? Let us help."
    subheadline="Book a 30-minute conversation and we will figure out the right engagement together."
  />
</PageLayout>
