---
import PageLayout from '@/layouts/PageLayout.astro'
---

<PageLayout title="Page Not Found">
  <section class="px-6 py-24">
    <div class="mx-auto max-w-xl text-center">
      <h1 class="font-serif text-5xl text-gold">404</h1>
      <p class="mt-4 text-lg text-text-muted">
        This page does not exist. Perhaps it was transmuted into something else.
      </p>
      <a
        href="/"
        class="mt-8 inline-block rounded-sm bg-accent px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      >
        Return home
      </a>
    </div>
  </section>
</PageLayout>
