---
import CTABand from '@/components/sections/CTABand.astro'
import { SITE_URL } from '@/consts'
import PageLayout from '@/layouts/PageLayout.astro'

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Adaptive Alchemy',
  url: SITE_URL,
  logo: `${SITE_URL}/assets/adaptive-alchemy-logo.png`,
  description:
    'Product and technology strategy leadership firm providing fractional CTO services, technical due diligence, and AI transformation advisory to growth-stage companies and their investors.',
  knowsAbout: [
    'AI Strategy',
    'Fractional CTO',
    'Product Strategy',
    'Technical Due Diligence',
    'AI Transformation',
    'Technology Assessment'
  ],
  serviceType: [
    'Fractional CTO Services',
    'Fractional CPTO Services',
    'Product & Technology Strategy Review',
    'Investor Readiness',
    'AI Transformation Advisory',
    'CTO Coaching'
  ]
}
---

<PageLayout
  title="About"
  description="Adaptive Alchemy is a collective of senior product and technology strategists who embed in your organization to solve product strategy, architecture, velocity, and AI transformation challenges."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(organizationSchema)}
  />
  <section class="px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-serif text-4xl text-text-primary md:text-5xl">
        Transform how you build.
      </h1>

      <div class="mt-12 space-y-6 text-lg leading-relaxed text-text-muted">
        <p>
          Adaptive Alchemy is a product and technology strategy leadership firm.
          We provide fractional CPTO-grade leadership — Chief Product and
          Technology Officer — combining product strategy and technology
          execution under one senior leader. Plus technical due diligence and
          agent-first transformation advisory for growth-stage companies and
          their investors.
        </p>

        <p>
          Most companies at this stage face a false choice: hire a fractional
          CTO for technology leadership, or a fractional CPO for product
          strategy, and hope they align. We eliminate that gap. One embedded
          leader who owns both what you build and how you build it — accountable
          for outcomes, not just recommendations.
        </p>

        <p>
          Our work is strategy-first by design. But strategy without delivery is
          theater. When implementation support is required, we help mobilize
          trusted operators and keep ownership of standards, decisions, and
          outcomes.
        </p>

        <h2 class="mt-12 font-serif text-2xl text-text-primary">
          Why &ldquo;Alchemy&rdquo;?
        </h2>

        <p>
          Alchemy is the art of transformation. We transform technical debt into
          technical leverage. We transform product uncertainty into strategic
          clarity. We transform AI curiosity into operational advantage. We
          transform scattered engineering efforts into compounding velocity.
        </p>

        <p>
          The companies that thrive in the next decade will be the ones that
          learn to work with AI agents as members of their teams — not just
          tools in their stack. We help organizations make that transformation
          deliberately, measurably, and sustainably.
        </p>

        <h2 class="mt-12 font-serif text-2xl text-text-primary">
          What we believe
        </h2>

        <ul class="space-y-4">
          <li class="border-l-2 border-gold/30 pl-4">
            <strong class="text-text-primary">
              Velocity is a clarity problem.
            </strong>
            When teams know exactly what success looks like, they stop debating and
            start building.
          </li>
          <li class="border-l-2 border-gold/30 pl-4">
            <strong class="text-text-primary">Structure beats talent.</strong>
            The highest-leverage investment is not better engineers — it is removing
            the structural drag that taxes everything they do.
          </li>
          <li class="border-l-2 border-gold/30 pl-4">
            <strong class="text-text-primary">
              Agent-first is an operating model, not a toolset.
            </strong>
            AI agents change how organizations work, not just how engineers code.
          </li>
          <li class="border-l-2 border-gold/30 pl-4">
            <strong class="text-text-primary">
              Please-to-thank-you time is the metric that matters.
            </strong>
            How long from request to delivered value? Everything else is a proxy.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <CTABand />
</PageLayout>
