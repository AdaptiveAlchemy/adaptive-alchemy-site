---
import PageLayout from '@/layouts/PageLayout.astro'
---

<PageLayout
  title="Insights"
  description="Strategic perspectives on technology leadership, technical due diligence, and agent-first transformation from Adaptive Alchemy."
>
  <section class="px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="font-serif text-4xl text-text-primary md:text-5xl">
        Insights
      </h1>
      <p class="mt-6 text-lg text-text-muted">
        Strategic perspectives on technology leadership, AI transformation, and
        what it takes to build organizations that compound.
      </p>
    </div>

    <!-- Blog listing will be populated from content collections -->
    <div class="mx-auto mt-16 max-w-3xl">
      <p class="text-center text-text-muted">
        Content coming soon. We are preparing our first articles on technical
        due diligence, fractional CTO leadership, and agent-first
        transformation.
      </p>
    </div>
  </section>
</PageLayout>
