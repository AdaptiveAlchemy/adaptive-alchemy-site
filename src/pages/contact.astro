---
import PageLayout from '@/layouts/PageLayout.astro'
---

<PageLayout
  title="Contact"
  description="Book a strategy session with Adaptive Alchemy. No pitch, no pressure — just clarity on your next step."
>
  <section class="px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="font-serif text-4xl text-text-primary md:text-5xl">
        Let&rsquo;s talk.
      </h1>

      <p class="mt-6 text-lg text-text-muted">
        Book a 30-minute strategy conversation. We will listen to where you are,
        ask the right questions, and tell you honestly whether we can help.
      </p>

      <div class="mt-12">
        <a
          href="mailto:inquiries@adaptivealchemy.io"
          class="inline-block rounded-sm bg-accent px-8 py-4 text-lg font-medium text-white transition-colors duration-200 hover:bg-accent-hover"
        >
          inquiries@adaptivealchemy.io
        </a>
      </div>

      <div class="mt-12 space-y-3 text-sm text-text-muted">
        <p class="font-medium text-text-primary">What happens next</p>
        <ul class="space-y-2">
          <li>We reply within one business day</li>
          <li>30-minute strategy conversation &mdash; no pitch, no pressure</li>
          <li>Honest assessment of whether we can help</li>
        </ul>
      </div>
    </div>
  </section>
</PageLayout>
