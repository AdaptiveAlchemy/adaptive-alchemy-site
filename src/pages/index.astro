---
import CTABand from '@/components/sections/CTABand.astro'
import Hero from '@/components/sections/Hero.astro'
import ServiceCards from '@/components/sections/ServiceCards.astro'
import { SITE_TITLE, SITE_URL } from '@/consts'
import PageLayout from '@/layouts/PageLayout.astro'
import { jsonLd } from '@/utils/json-ld'

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Adaptive Alchemy',
  url: SITE_URL,
  description:
    'Product and technology strategy leadership for growth-stage companies and their investors.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '30 N Gould St #24790',
    addressLocality: 'Sheridan',
    addressRegion: 'WY',
    postalCode: '82801',
    addressCountry: 'US'
  },
  telephone: '+1-307-454-0093',
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    telephone: '+1-307-454-0093',
    email: 'inquiries@adaptivealchemy.io'
  }
}
---

<PageLayout
  title={SITE_TITLE}
  description="Adaptive Alchemy: fractional CTO services, product and technology strategy consulting, and technical due diligence for growth-stage companies and PE/VC funds. Senior product and technology leadership, on demand."
>
  <script
    is:inline
    type="application/ld+json"
    set:html={jsonLd(websiteSchema)}
  />
  <Hero />

  <!-- Problem statements — in the buyer's voice -->
  <section class="px-6 py-20">
    <div class="mx-auto max-w-7xl">
      <h2 class="text-center font-serif text-3xl text-text-primary md:text-4xl">
        We solve the problems that keep product and technology leaders up at
        night.
      </h2>

      <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2">
        <div class="rounded-lg border border-white/5 p-8">
          <p class="text-lg italic leading-relaxed text-text-muted">
            &ldquo;We are shipping features but not moving the needle on what
            matters.&rdquo;
          </p>
          <a
            href="/services/fractional-cto"
            class="mt-4 inline-block text-sm text-accent hover:text-accent-hover"
          >
            Fractional CTO Leadership &rarr;
          </a>
        </div>

        <div class="rounded-lg border border-white/5 p-8">
          <p class="text-lg italic leading-relaxed text-text-muted">
            &ldquo;Investors are asking questions about our architecture I can't
            confidently answer.&rdquo;
          </p>
          <a
            href="/services/technology-strategy-assessment"
            class="mt-4 inline-block text-sm text-accent hover:text-accent-hover"
          >
            Product &amp; Technology Strategy Review &rarr;
          </a>
        </div>

        <div class="rounded-lg border border-white/5 p-8">
          <p class="text-lg italic leading-relaxed text-text-muted">
            &ldquo;We need to be ready for due diligence in 90 days.&rdquo;
          </p>
          <a
            href="/services/investor-readiness"
            class="mt-4 inline-block text-sm text-accent hover:text-accent-hover"
          >
            Investor Readiness Program &rarr;
          </a>
        </div>

        <div class="rounded-lg border border-white/5 p-8">
          <p class="text-lg italic leading-relaxed text-text-muted">
            &ldquo;Everyone is talking about AI agents but we don't even know
            where to start.&rdquo;
          </p>
          <a
            href="/services/agent-first-transformation"
            class="mt-4 inline-block text-sm text-accent hover:text-accent-hover"
          >
            Agent-First Transformation &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Credibility -->
  <section class="border-y border-white/5 bg-surface px-6 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-serif text-3xl text-text-primary md:text-4xl">
        Senior practitioners embedded in your team.
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-text-muted">
        We have built product and technology organizations from early stages
        through exits. Across decades, industries, and every company size from
        pre-seed to Fortune 50. The work has run both technical and commercial:
        not just engineering and architecture, but revenue pipelines, cost
        transformation, and organizational change. Most of what genuinely blocks
        companies lives at the intersection of those two.
      </p>
      <a
        href="/about"
        class="mt-8 inline-block text-sm text-accent hover:text-accent-hover"
      >
        Learn about our approach &rarr;
      </a>
    </div>
  </section>

  <ServiceCards />

  <CTABand />
</PageLayout>
