---
export interface Props {
  heading: string
  items: ReadonlyArray<{ eyebrow: string; title: string; description: string }>
}

const { heading, items } = Astro.props
---

<section class="px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <h2 class="text-center font-serif text-3xl text-text-primary md:text-4xl">
      {heading}
    </h2>

    <div class="mt-12 space-y-12">
      {
        items.map(({ eyebrow, title, description }) => (
          <div>
            <p class="text-sm uppercase tracking-wide text-gold">{eyebrow}</p>
            <h3 class="mt-2 font-serif text-xl text-text-primary">{title}</h3>
            <p class="mt-3 text-text-muted">{description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
