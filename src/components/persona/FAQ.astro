---
export interface Props {
  items: ReadonlyArray<{ question: string; answer: string }>
}

const { items } = Astro.props
---

<section class="border-y border-white/5 bg-surface px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <h2 class="text-center font-serif text-3xl text-text-primary md:text-4xl">
      Frequently Asked Questions
    </h2>

    <dl class="mt-12 space-y-8">
      {
        items.map(({ question, answer }) => (
          <div class="border-b border-white/5 pb-8 last:border-b-0">
            <dt class="text-lg font-medium text-text-primary">{question}</dt>
            <dd class="mt-3 text-base leading-relaxed text-text-muted">
              {answer}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
