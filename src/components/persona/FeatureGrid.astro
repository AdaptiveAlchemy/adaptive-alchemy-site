---
export interface Props {
  heading: string
  subheading?: string
  items: ReadonlyArray<{ title: string; description: string }>
}

const { heading, subheading, items } = Astro.props
---

<section class="px-6 py-20">
  <div class="mx-auto max-w-7xl">
    <h2 class="text-center font-serif text-3xl text-text-primary md:text-4xl">
      {heading}
    </h2>
    {
      subheading && (
        <p class="mx-auto mt-4 max-w-2xl text-center text-lg text-text-muted">
          {subheading}
        </p>
      )
    }

    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        items.map(({ title, description }) => (
          <div class="rounded-lg border border-gold/20 bg-surface p-6">
            <h3 class="font-serif text-xl text-text-primary">{title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-text-muted">
              {description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
