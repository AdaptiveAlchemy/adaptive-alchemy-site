---
export interface Props {
  headline?: string
  subheadline?: string
  primaryCta?: { label: string; href: string }
  secondaryCta?: { label: string; href: string }
}

const {
  headline = 'Your technology should be your advantage. Not your anxiety.',
  subheadline = 'Adaptive Alchemy provides the senior product and technology leadership that growth-stage companies and their investors need — strategic clarity, execution velocity, and a clear path to agent-first operations.',
  primaryCta = { label: 'Book a Strategy Session', href: '/contact' },
  secondaryCta = { label: 'Assess Your Readiness', href: '/approach' }
} = Astro.props
---

<section class="relative overflow-hidden px-6 py-24 md:py-32 lg:py-40">
  <!-- Subtle geometric background pattern -->
  <div
    class="pointer-events-none absolute inset-0 opacity-5"
    aria-hidden="true"
  >
    <div
      class="absolute left-1/4 top-1/4 h-64 w-64 rotate-45 border border-gold"
    >
    </div>
    <div
      class="absolute right-1/4 top-1/3 h-48 w-48 rounded-full border border-gold/50"
    >
    </div>
  </div>

  <div class="relative mx-auto max-w-4xl text-center">
    <h1
      class="text-balance font-serif text-4xl leading-tight text-text-primary md:text-5xl lg:text-6xl"
    >
      {headline}
    </h1>

    <p
      class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-text-muted md:text-xl"
    >
      {subheadline}
    </p>

    <div
      class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
    >
      <a
        href={primaryCta.href}
        class="rounded-sm bg-accent px-8 py-3.5 text-sm font-medium text-white transition-colors duration-200 hover:bg-accent-hover"
      >
        {primaryCta.label}
      </a>
      <a
        href={secondaryCta.href}
        class="rounded-sm border border-gold/30 px-8 py-3.5 text-sm font-medium text-gold transition-colors duration-200 hover:border-gold hover:text-gold-light"
      >
        {secondaryCta.label}
      </a>
    </div>
  </div>
</section>
