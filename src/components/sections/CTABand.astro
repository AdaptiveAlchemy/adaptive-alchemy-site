---
export interface Props {
  headline?: string
  subheadline?: string
  ctaLabel?: string
  ctaHref?: string
}

const {
  headline = 'Not sure where to start? That is exactly why we exist.',
  subheadline = 'Book a 30-minute strategy conversation. No pitch, no pressure. Just clarity on your next step, and a practical path to get the work done.',
  ctaLabel = 'Book a Strategy Session',
  ctaHref = '/contact'
} = Astro.props
---

<section class="border-y border-gold/10 bg-ink px-6 py-20">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="font-serif text-3xl text-text-primary md:text-4xl">
      {headline}
    </h2>
    <p class="mt-4 text-lg text-text-muted">
      {subheadline}
    </p>
    <a
      href={ctaHref}
      class="mt-8 inline-block rounded-sm bg-accent px-8 py-3.5 text-sm font-medium text-white transition-colors duration-200 hover:bg-accent-hover"
    >
      {ctaLabel}
    </a>
  </div>
</section>
