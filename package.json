{
  "name": "adaptive-alchemy-site",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check:astro": "astro check",
    "check": "pnpm check:astro",
    "predeploy": "pnpm build",
    "deploy": "gh-pages -d dist",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules --ignore .docs --ignore .claude",
    "lint:md:fix": "markdownlint --fix '**/*.md' --ignore node_modules --ignore .docs --ignore .claude",
    "lint:format": "prettier --check .",
    "lint:format:fix": "prettier --write .",
    "lint:format:src": "prettier --check 'src/**/*.{js,jsx,ts,tsx,astro}'",
    "lint:format:src:fix": "prettier --write 'src/**/*.{js,jsx,ts,tsx,astro}'",
    "lint:format:css": "prettier --check 'src/**/*.{css,astro}'",
    "lint:format:css:fix": "prettier --write 'src/**/*.{css,astro}'",
    "lint:code": "eslint",
    "lint:code:fix": "eslint --fix",
    "lint:code:src": "eslint src",
    "lint:code:src:fix": "eslint --fix src",
    "lint:styles": "stylelint 'src/**/*.{css,astro}'",
    "lint:styles:fix": "stylelint 'src/**/*.{css,astro}' --fix",
    "lint": "pnpm run lint:format:src && pnpm run lint:format:css && pnpm run lint:code:src && pnpm run lint:styles && pnpm run lint:md",
    "lint:fix": "pnpm run lint:format:src:fix && pnpm run lint:format:css:fix && pnpm run lint:code:src:fix && pnpm run lint:styles:fix && pnpm run lint:md:fix",
    "type-check": "pnpm check:astro",
    "a11y": "pnpm build && axe http://localhost:4321 http://localhost:4321/about http://localhost:4321/services http://localhost:4321/approach http://localhost:4321/contact --exit",
    "a11y:ci": "pnpm build && lhci autorun",
    "lighthouse": "pnpm build && lhci autorun"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/sitemap": "3.7.2",
    "@tailwindcss/postcss": "^4.1.10",
    "@tailwindcss/vite": "^4.1.10",
    "astro": "^6.1.7",
    "astro-seo": "^0.8.4",
    "framer-motion": "^12.6.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "reading-time": "^1.5.0",
    "tailwindcss": "^4.1.10"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@axe-core/cli": "^4.11.1",
    "@eslint/js": "^9.29.0",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/typography": "^0.5.9",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^24.0.3",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.1.2",
    "markdownlint-cli": "^0.45.0",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.12.0",
    "prettier-plugin-tailwindcss": "^0.5.4",
    "sharp": "^0.34.2",
    "stylelint": "^16.20.0",
    "stylelint-config-alphabetical-order": "^1.0.0",
    "stylelint-config-astro": "^1.0.4",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-recommended": "^16.0.0",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-config-tailwindcss": "^1.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.34.1"
  }
}
